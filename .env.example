# AdaptiveMemoryEngine - Environment Configuration
# Copy this file to .env and update the values

# Server Configuration
PORT=3000
DATA_DIR=./data

# Required: OpenAI API Key for embeddings
# AdaptiveMemoryEngine requires semantic embeddings
OPENAI_API_KEY=sk-your-openai-api-key-here

# Optional: Embedding model
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Optional: Intelligence model for AI-enhanced features
# (auto-tagging, ask, summarize, smart graph extraction)
OPENAI_CHAT_MODEL=gpt-4o-mini

# Optional: Transport mode
# stdio = default, for local MCP clients
# sse   = HTTP+SSE server mode, for remote deployment
TRANSPORT=stdio
