# AdaptiveMemoryEngine - Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# AI PROVIDER CONFIGURATION
# Choose ONE provider setup below
# =============================================================================

# Option 1: OpenAI (default, recommended)
# Get key: https://platform.openai.com/api-keys
PROVIDER_TYPE=openai
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_CHAT_MODEL=gpt-4o-mini

# Option 2: Ollama (local, free, private)
# Install: https://ollama.com
# Then run: ollama pull nomic-embed-text && ollama pull llama3.2
# PROVIDER_TYPE=ollama
# OLLAMA_HOST=http://localhost:11434
# OLLAMA_EMBEDDING_MODEL=nomic-embed-text
# OLLAMA_CHAT_MODEL=llama3.2

# Option 3: Google Gemini (free tier available)
# Get key: https://aistudio.google.com/app/apikey
# PROVIDER_TYPE=gemini
# GEMINI_API_KEY=your-gemini-api-key
# GEMINI_EMBEDDING_MODEL=text-embedding-004
# GEMINI_CHAT_MODEL=gemini-1.5-flash

# =============================================================================
# OPTIONAL: SEPARATE INTELLIGENCE PROVIDER
# Use a different provider for AI features (ask, summarize, auto-tag)
# while keeping embeddings on another provider
# =============================================================================

# Example: OpenAI embeddings + Anthropic intelligence
# PROVIDER_TYPE=openai
# OPENAI_API_KEY=sk-...
# INTELLIGENCE_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-3-haiku-20240307

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================

# Data directory (default: ./data)
DATA_DIR=./data

# Server port for SSE mode (default: 3000)
PORT=3000

# Transport mode: stdio (default) or sse
# stdio = for Claude Desktop, Cline (local)
# sse   = HTTP server mode (remote)
TRANSPORT=stdio

# =============================================================================
# ADVANCED OPTIONS
# =============================================================================

# Custom model overrides (provider-specific)
# EMBEDDING_MODEL=text-embedding-3-small
# CHAT_MODEL=gpt-4o-mini
